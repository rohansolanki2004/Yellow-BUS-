<h1>Login Page</h1>
<%=form_with url: login_path , method: :post do %>
    <div>
       <label>Email</label>
       <%= text_field_tag :email %>
    </div>

    <div>
        <label>Password</label>
        <%= password_field_tag :password %>
    </div>
 
    <div>
       <%=submit_tag "login" %>
    </div>
<% end %>
