<%= form_with(model: [@bus, @schedule], local: true) do |form| %>

  <% if @schedule.errors.any? %>
    <div>
      <h2><%= pluralize(@schedule.errors.count, "error") %> prevented saving:</h2>
      <ul>
        <% @schedule.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<div>
  <%= form.label :route_id, "Route" %><br>
  <%= form.collection_select :route_id, Route.all, :id, :display_name, prompt: "Select Route" %>
</div>

  <div>
    <%= form.label :departure_time %><br>
    <%= form.datetime_select :departure_time %>
  </div>

  <div>
    <%= form.label :arrival_time %><br>
    <%= form.datetime_select :arrival_time %>
  </div>

  <div>
    <%= form.submit %>
  </div>

<% end %>